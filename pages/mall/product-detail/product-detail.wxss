page {
  background-color: #1C392F;
}

.product-detail {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.main-image {
  width: 100%;
  height: 500rpx;
  background: #152E25;
  display: flex;
  align-items: center;
  justify-content: center;
}

.main-image image {
  width: 80%;
  height: 400rpx;
}

.info-card {
  margin: 30rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
}

.title {
  font-size: 32rpx;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.price {
  font-size: 36rpx;
  color: #FFFFFF;
}

.description-card, .detail-card {
  margin: 0 30rpx 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
}

.section-title {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.description {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.detail-image {
  width: 100%;
  border-radius: 8rpx;
} 