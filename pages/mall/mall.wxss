/* pages/mall/mall.wxss */
page {
  background-color: #1C392F;
}

.bg-image {
  position: fixed;
  width: 100%;
  height: 180%;
  top: 0;
  left: 0;
  z-index: -1;
}

.mall {
  padding: 20rpx;
  margin-top: 80vw;
}

.section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 40rpx;
  color: #FFF5C0;
  font-weight: 500;
}

.section-more {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 文创商品样式 */
.product-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 240rpx;
}

.product-info {
  padding: 16rpx;
}

.product-title {
  font-size: 26rpx;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 文教课程样式 */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  overflow: hidden;
}

.course-image {
  width: 100%;
  height: 360rpx;
}

.course-title {
  display: block;
  padding: 16rpx;
  font-size: 26rpx;
  color: #FFFFFF;
}