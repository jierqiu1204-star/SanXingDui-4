page {
  background-color: #1C392F;
}

.activity-detail {
  min-height: 100vh;
}

.banner {
  width: 100%;
  height: 400rpx;
}

.main-card {
  margin: 20rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  min-height: calc(100vh - 440rpx);
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.content-card {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  min-height: 200rpx;
}

.content {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
} 