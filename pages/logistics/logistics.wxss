page {
  background: #1C392F;
}

.logistics-container {
  padding: 20rpx;
  position: relative;
}

.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.tracking-number {
  background: #C2CEBD;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.carrier {
  font-size: 28rpx;
  color: #1C392F;
}

.number {
  font-size: 28rpx;
  color: #1C392F;
}

.timeline {
  background: #C2CEBD;
  padding: 30rpx;
  border-radius: 12rpx;
}

.timeline-item {
  display: flex;
  position: relative;
}

.time-line {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #1C392F;
  opacity: 0.5;
}

.active .dot {
  opacity: 1;
  width: 20rpx;
  height: 20rpx;
}

.line {
  width: 2rpx;
  height: 100rpx;
  background: #1C392F;
  opacity: 0.3;
}

.info {
  flex: 1;
  padding-bottom: 30rpx;
}

.status {
  font-size: 28rpx;
  color: #1C392F;
  margin-bottom: 8rpx;
}

.active .status {
  font-weight: bold;
}

.time {
  font-size: 24rpx;
  color: rgba(28, 57, 47, 0.6);
  margin-bottom: 8rpx;
}

.detail {
  font-size: 24rpx;
  color: rgba(28, 57, 47, 0.8);
}

.waiting-text {
  font-size: 28rpx;
  color: #1C392F;
  text-align: center;
  width: 100%;
} 