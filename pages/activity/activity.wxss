page {
  background-image: url('/images/common/green.png') !important;
  background-size: cover;
  background-repeat: no-repeat;
  background-position: center;
  background-color: #1C392F;
}

.container {
  position: relative;
  min-height: 100vh;
}

.bg-image {
  position: fixed;
  top: -100rpx;
  left: 0;
  width: 100%;
  height: 200%;
  z-index: -1;
}

.articles {
  padding: 20rpx 30rpx;
  margin-top: -150rpx;
}

.article-item {
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-section {
  width: 100%;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.15);
}

.article-image {
  width: 100%;
  height: 100%;
}

.info-section {
  background: rgba(255, 255, 255, 0.1);
  padding: 24rpx;
}

.article-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.article-title {
  flex: 1;
  font-size: 28rpx;
  color: #FFFFFF;
}

.collect-btn {
  padding: 10rpx;
}

.star-icon {
  width: 40rpx;
  height: 40rpx;
}

.article-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}