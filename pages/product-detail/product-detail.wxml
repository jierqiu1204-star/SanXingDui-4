<view class="product-detail">
  <!-- 添加背景图片 -->
  <image class="background-image" src="/images/background.png" mode="aspectFill"></image>
  
  <view class="info-card">
    <view class="image-container">
      <image src="{{product.image}}" mode="aspectFit"></image>
    </view>
    <view class="info-content">
      <view class="title">{{product.name}}</view>
      <view class="price">{{product.price}} </view>
    </view>
  </view>

  <view class="intro-card">
    <view class="section-title">产品介绍</view>
    <view class="intro-text">{{product.description}}</view>
  </view>

  <view class="detail-card">
    <view class="section-title">{{product.detailTitle}}</view>
    <view class="detail-image-container">
      <image class="detail-image" src="{{product.image}}" mode="aspectFit"></image>
    </view>
    <block wx:if="{{product.detailImages && product.detailImages.length > 0}}">
      <view class="detail-images-grid">
        <view 
          wx:for="{{product.detailImages}}" 
          wx:key="*this"
          class="detail-extra-image">
          <image src="{{item}}" mode="aspectFit"></image>
        </view>
      </view>
    </block>
  </view>

  <view class="action-buttons">
    <view class="btn-group">
      <button class="action-btn cart-btn" bindtap="showCartPopup">加入购物车</button>
      <button class="action-btn buy-btn" bindtap="showBuyPopup">立即购买</button>
    </view>
  </view>

  <!-- 加入购物车弹窗 -->
  <view class="popup-mask" wx:if="{{showCartPopup}}" bindtap="hideCartPopup"></view>
  <view class="popup-content {{showCartPopup ? 'popup-show' : ''}}">
    <view class="popup-main">
      <!-- 顶部大图 -->
      <view class="popup-banner">
        <image src="{{product.image}}" mode="aspectFit"></image>
      </view>

      <!-- 商品信息卡片 -->
      <view class="popup-card info-card">
        <view class="popup-title">{{product.name}}</view>
        <view class="popup-price">{{product.price}} </view>
        <view class="quantity-control">
          <text class="quantity-btn" bindtap="decreaseQuantity">-</text>
          <text class="quantity-num">{{quantity}}</text>
          <text class="quantity-btn" bindtap="increaseQuantity">+</text>
        </view>
      </view>

      <button class="popup-btn" bindtap="addToCart">加入购物车</button>
    </view>
  </view>

  <!-- 立即购买弹窗 -->
  <view class="popup-mask" wx:if="{{showBuyPopup}}" bindtap="hideBuyPopup"></view>
  <view class="popup-content {{showBuyPopup ? 'popup-show' : ''}}">
    <view class="popup-main">
      <!-- 顶部大图 -->
      <view class="popup-banner">
        <image src="{{product.image}}" mode="aspectFit"></image>
      </view>

      <!-- 商品信息卡片 -->
      <view class="popup-card info-card">
        <view class="popup-title">{{product.name}}</view>
        <view class="popup-price">{{product.price}} </view>
        <view class="quantity-control">
          <text class="quantity-btn" bindtap="decreaseQuantity">-</text>
          <text class="quantity-num">{{quantity}}</text>
          <text class="quantity-btn" bindtap="increaseQuantity">+</text>
        </view>
      </view>

      <button class="popup-btn" bindtap="buyNow">立即购买</button>
    </view>
  </view>
</view> 