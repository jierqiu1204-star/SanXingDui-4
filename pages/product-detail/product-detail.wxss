page {
  background-color: #1C392F;
}

.product-detail {
  min-height: 100vh;
  padding: 0 30rpx 30rpx;
  position: relative;  /* 添加相对定位 */
}

/* 添加背景图片样式 */
.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;  /* 确保背景在最底层 */
}

.info-card {
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.image-container {
  width: 100%;
  height: 500rpx;
  background: #152E25;  /* 深绿色背景 */
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-container image {
  width: 200%;
  height: 300rpx;
}

.info-content {
  background: rgba(208, 223, 208, 0.7);  /* 浅绿色背景 */
  padding: 24rpx;
}

.title {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.price {
  font-size: 32rpx;
  color: #333333;
}

.intro-card, .detail-card {
  background: #C2CEBD;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.intro-text {
  font-size: 28rpx;
  color: rgb(51, 51, 51);
  line-height: 1.6;
}

.detail-image-container {
  width: 100%;
  height: 400rpx;
  background: #C2CEBD;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  overflow: hidden;
}

.detail-image {
  width: 60%;
  height: 300rpx;
}

.detail-images-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.detail-extra-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: #C2CEBD;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-extra-image image {
  width: 60%;
  height: 300rpx;
}

/* 添加按钮样式 */
.action-buttons {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
}

.btn-group {
  width: 400rpx;  /* 整个椭圆形的宽度 */
  height: 80rpx;
  background: rgba(208, 223, 208, 0.7);  /* 左半部分的背景色 */
  border-radius: 40rpx;
  display: flex;
  overflow: hidden;
}

.action-btn {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  line-height: 80rpx;
  text-align: center;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 0;
  background: transparent;
}

.cart-btn {
  color: #333333;
}

.buy-btn {
  background:rgb(241, 244, 225);  /* 右半部分的背景色 */
  color: #333333;
}

/* 重置按钮默认样式 */
button {
  margin: 0;
  padding: 0;
}

button::after {
  border: none;
}

/* 弹窗相关样式 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 1;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.popup-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 101;
}

.popup-show {
  transform: translateY(0);
}

.popup-main {
  background: #C2CEBD;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  height: 600rpx;
}

.popup-banner {
  height: 200rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.popup-banner image {
  height: 100%;
  width: 200rpx;
  object-fit: contain;
}

.popup-card.info-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.image-list-card {
  display: flex;
  justify-content: space-between;
}

.image-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.small-image {
  width: 120rpx;
  height: 120rpx;
  background: #152E25;  /* 深绿色背景 */
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.image-item text {
  font-size: 24rpx;
  color: #333333;
}

.popup-title {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.popup-price {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 20rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
}

.quantity-btn {
  font-size: 32rpx;
  color: #333333;
  padding: 0 20rpx;
}

.quantity-num {
  font-size: 32rpx;
  color: #333333;
  min-width: 60rpx;
  text-align: center;
}

.popup-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #1C392F;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-top: 32rpx;
}

/* 去掉按钮点击时的默认样式 */
.add-cart-btn::after {
  border: none;
}

/* 按钮点击效果 */
.add-cart-btn:active {
  opacity: 0.8;
}