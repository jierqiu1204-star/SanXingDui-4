/**index.wxss**/
.page {
  width: 100%;
  min-height: 100%;
  background-image: url('/images/common/background.png');  
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  display: flex;
  flex-direction: column;
  background-color: #1C392F;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.userinfo {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #aaa;
  width: 80%;
}

.userinfo-avatar {
  overflow: hidden;
  width: 128rpx;
  height: 128rpx;
  margin: 20rpx;
  border-radius: 50%;
}

.usermotto {
  margin-top: 200px;
}

.avatar-wrapper {
  padding: 0;
  width: 56px !important;
  border-radius: 8px;
  margin-top: 40px;
  margin-bottom: 40px;
}

.avatar {
  display: block;
  width: 56px;
  height: 56px;
}

.nickname-wrapper {
  display: flex;
  width: 100%;
  padding: 16px;
  box-sizing: border-box;
  border-top: .5px solid rgba(0, 0, 0, 0.1);
  border-bottom: .5px solid rgba(0, 0, 0, 0.1);
  color: black;
}

.nickname-label {
  width: 105px;
}

.nickname-input {
  flex: 1;
}

.container {
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

/* 顶部标题样式 */
.header {
  margin-bottom: 40rpx;
}

.header-text {
  display: block;
  color: #D4B475;
  font-size: 36rpx;
  line-height: 1.5;
}

/* 主要内容区域 */
.main-section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 70vw;
}

/* 模块样式 */
.module {
  margin-bottom: 40rpx;
}

.module:last-child {
  margin-bottom: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  color: #FFF5C0;
  font-size: 40rpx;
  font-weight: 500;
}

.section-more {
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
}

/* 活动列表样式 */
.activity-list {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.activity-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  overflow: hidden;
}

.activity-image {
  width: 100%;
  height: 240rpx;
  background-color: #2A4A41;
}

.activity-info {
  padding: 20rpx;
}

.activity-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.activity-text {
  flex: 1;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 0;
}

.collect-btn {
  padding: 10rpx;
}

.star-icon {
  width: 40rpx;
  height: 40rpx;
}

.activity-date {
  display: block;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  padding: 0;
}

/* 文章列表样式 */
.article-list {
  width: 100%;
}

.article-item {
  width: 100%;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  overflow: hidden;
}

.article-image {
  width: 100%;
  height: 300rpx;
  background-color: #2A4A41;
}

.article-text {
  display: block;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 20rpx;
}

.bg-image {
  position: fixed;
  top: -100rpx;
  left: 0;
  width: 100%;
  height: 200%;
  z-index: -1;
}
