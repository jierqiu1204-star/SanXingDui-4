page {
  background-color: #1C392F;
}

.collection-container {
  padding: 20rpx 30rpx;
  position: relative;
}

.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.tab {
  background: #C2CEBD;
  color: #1C392F;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.tab.active {
  background: #C2CEBD;
  opacity: 0.9;
}

.content-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item {
  background: #C2CEBD;
  border-radius: 16rpx;
  overflow: hidden;
}

.item-image {
  width: 100%;
  height: 360rpx;
  display: block;
  background: #C4C4C4;
}

.item-info {
  padding: 24rpx;
  background: #C2CEBD;
}

.item-title {
  display: block;
  color: #1C392F;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.item-date {
  display: block;
  color: rgba(28, 57, 47, 0.6);
  font-size: 24rpx;
} 