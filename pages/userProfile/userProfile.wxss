page {
  background-color: #1C392F;
}

.profile-container {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrapper {
  padding: 0;
  width: 240rpx !important;
  height: 240rpx;
  margin-bottom: 80rpx;
  background: none;
}

.avatar-wrapper::after {
  border: none;
}

.avatar-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 120rpx;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  justify-content: center;
  align-items: center;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 90rpx;
}

.input-container {
  width: 100%;
  margin-bottom: 80rpx;
}

.nickname-input {
  width: 100%;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
  font-size: 36rpx;
  color: #FFFFFF;
  text-align: center;
}

.placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.btn-container {
  width: 100%;
  position: fixed;
  bottom: 100rpx;
  left: 0;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.save-btn {
  width: 100% !important;
  height: 100rpx;
  line-height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 36rpx;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 !important;
}

.save-btn::after {
  border: none;
} 