/* pages/cart/cart.wxss */
page {
  background: #1C392F;
}

.cart-container {
  padding: 20rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  position: relative;
}

.search-box {
  background: #C2CEBD;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.search-box input {
  flex: 1;
  margin: 0 20rpx;
  font-size: 28rpx;
  color: #1C392F;
}

.cart-item {
  background: #C2CEBD;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 28rpx;
  color: #1C392F;
  margin-bottom: 12rpx;
}

.product-spec {
  font-size: 24rpx;
  color: rgba(28, 57, 47, 0.8);
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.arrow {
  color: #1C392F;
  font-size: 24rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 28rpx;
  color: #1C392F;
}

.quantity-control {
  display: flex;
  align-items: center;
  background: #ECF4E4;
  border-radius: 8rpx;
}

.minus, .plus {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1C392F;
}

.quantity {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1C392F;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #C2CEBD;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total {
  font-size: 32rpx;
  color: #1C392F;
  font-weight: bold;
}

.confirm-btn {
  background: #ECF4E4;
  padding: 20rpx 40rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #1C392F;
}

.select-circle {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #1C392F;
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inner-circle {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: transparent;
}

.inner-circle.selected {
  background: #1C392F;
}

/* 规格选择弹窗样式 */
.spec-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.spec-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #C2CEBD;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 101;
}

.spec-popup.show {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.popup-close {
  font-size: 40rpx;
  color: #1C392F;
  padding: 10rpx;
}

.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-item {
  padding: 20rpx 40rpx;
  background: #ECF4E4;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1C392F;
}

.spec-item.selected {
  background: #1C392F;
  color: #ECF4E4;
}

/* 在原有样式基础上添加 */
.course-info {
  flex: 1;
  padding: 20rpx;
}

.course-title {
  font-size: 28rpx;
  color: #1C392F;
  display: block;
  margin-bottom: 12rpx;
}

.course-price {
  font-size: 26rpx;
  color: rgba(28, 57, 47, 0.8);
  display: block;
}

/* 添加背景图片样式 */
.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}