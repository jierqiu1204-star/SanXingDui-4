page {
  background-color: #1C392F;
  min-height: 100vh;
}

.product-page {
  padding: 20rpx;
  position: relative;
}

/* 添加背景图片样式 */
.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

/* 主卡片样式 */
.main-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 20rpx;
  position: relative;
}

/* 商品网格布局 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

/* 商品项样式 */
.product-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 240rpx;
  background: #1C392F;
}

.product-info {
  padding: 16rpx;
}

.product-price {
  display: block;
  font-size: 28rpx;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.product-title {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
} 