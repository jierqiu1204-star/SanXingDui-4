page {
  background: #1C392F;
}

.about-container {
  padding: 20rpx;
  position: relative;
}

.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.about-image {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.about-content {
  background: #C2CEBD;
  border-radius: 16rpx;
  padding: 30rpx;
}

.about-title {
  font-size: 32rpx;
  color: #1C392F;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.about-text {
  font-size: 28rpx;
  color: #1C392F;
  line-height: 1.6;
} 