page {
  background-color: #1C392F;
}

.orders-container {
  padding: 20rpx 30rpx;
  position: relative;
}

/* 添加背景图片样式 */
.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

/* 搜索框样式 */
.search-box {
  display: flex;
  align-items: center;
  background: #C2CEBD;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  margin-bottom: 20rpx;
}

.search-box icon {
  margin-right: 12rpx;
}

.search-box input {
  flex: 1;
  font-size: 28rpx;
  color: #1C392F;
}

.placeholder {
  color: rgba(28, 57, 47, 0.6);
}

/* 导航标签样式 */
.tabs {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.tabs-content {
  display: inline-flex;
  padding: 10rpx 0;
}

.tab {
  padding: 12rpx 30rpx;
  margin-right: 20rpx;
  background: #C2CEBD;
  color: #1C392F;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.tab.active {
  opacity: 0.9;
}

/* 订单列表样式 */
.orders-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  background: #C2CEBD;
  border-radius: 16rpx;
  padding: 24rpx;
}

.product-info {
  display: flex;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(28, 57, 47, 0.1);
}

.product-info:last-child {
  border-bottom: none;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #1C392F;
  margin-right: 20rpx;
}

.product-details {
  flex: 1;
}

.product-name {
  font-size: 28rpx;
  color: #1C392F;
  margin-bottom: 8rpx;
}

.product-spec {
  font-size: 24rpx;
  color: rgba(28, 57, 47, 0.6);
  margin-bottom: 16rpx;
}

.price-quantity {
  font-size: 26rpx;
  color: #1C392F;
}

.quantity {
  margin-left: 16rpx;
  color: rgba(28, 57, 47, 0.6);
}

.total-paid {
  text-align: right;
  font-size: 26rpx;
  color: #1C392F;
}

.amount {
  font-weight: bold;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(28, 57, 47, 0.1);
}

.delete-btn {
  padding: 12rpx 24rpx;
  background: #ECF4E4;
  color: #1C392F;
  font-size: 24rpx;
  border-radius: 24rpx;
}

.delete-btn:active {
  opacity: 0.8;
} 