page {
  background-color: #1C392F;
}

.course-detail {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.course-image {
  width: 100%;
  height: 400rpx;
}

/* 浅绿色主卡片 */
.main-card {
  margin: 24rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  color: #FFFFFF;
}

.course-title {
  font-size: 36rpx;
  margin-bottom: 16rpx;
}

.course-basic-info {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.course-basic-info text {
  margin-right: 32rpx;
}

.course-people {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 32rpx;
}

/* 浅黄色详情卡片 */
.detail-card {
  background: rgba(255, 236, 204, 0.1);
  border-radius: 16rpx;
  padding: 32rpx;
}

.info-section {
  margin-bottom: 32rpx;
}

.info-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.section-content {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.activity-image {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
}

/* 底部按钮样式 */
.bottom-actions {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  display: flex;
  justify-content: flex-end;
}

.action-button {
  display: flex;
  width: 320rpx;
  height: 72rpx;
  border-radius: 36rpx;
  overflow: hidden;
}

.cart-btn, .buy-btn {
  width: 50%;
  height: 100%;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
}

.cart-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.buy-btn {
  background: #FFFFFF;
  color: #1C392F;
} 