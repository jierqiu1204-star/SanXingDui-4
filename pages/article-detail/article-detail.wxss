page {
  background-color: #1C392F;
}

.article-detail {
  min-height: 100vh;
  padding: 30rpx;
}

.banner {
  width: 100%;
  height: 400rpx;
}

.main-card {
  margin: 20rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  min-height: calc(100vh - 440rpx);
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  color: #FFF5C0;
  margin-bottom: 40rpx;
  text-align: center;
  font-weight: bold;
}

.date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.content-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-top: 20rpx;
}

.content {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  text-align: justify;
  white-space: pre-wrap;
} 