page {
  background-color: #1C392F;
}

.articles {
  padding: 20rpx 30rpx;
}

.article-item {
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-section {
  width: 100%;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.15);
}

.article-image {
  width: 100%;
  height: 100%;
}

.info-section {
  background: rgba(255, 255, 255, 0.1);
  padding: 24rpx;
}

.article-title {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.article-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
} 