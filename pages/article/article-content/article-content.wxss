page {
  background-color: #1C392F;
}

.article-content {
  min-height: 100vh;
}

.banner {
  width: 100%;
  height: 400rpx;
}

.title {
  margin: 30rpx;
  font-size: 32rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.1);
  padding: 24rpx;
  border-radius: 16rpx;
}

.content-card {
  margin: 0 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  overflow: hidden;
}

.content-title {
  font-size: 28rpx;
  color: #FFFFFF;
  padding: 24rpx;
}

.content {
  background: rgba(255, 255, 255, 0.05);
  padding: 24rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
  min-height: 200rpx;
} 