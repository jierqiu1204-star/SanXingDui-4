/* pages/profile/profile.wxss */
page {
  background-color: #1C392F;
}

.profile-container {
  padding: 40rpx 30rpx;
  position: relative;
}

.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 20rpx;
}

.login-text {
  color: #FFFFFF;
  font-size: 32rpx;
  margin-bottom: 10rpx;
}

.user-id {
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
}

.user-nickname {
  color: #FFFFFF;
  font-size: 32rpx;
  margin-bottom: 10rpx;
}

.menu-list {
  margin-top: 40rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  background: #C2CEBD;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.menu-content {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-item text {
  color: #1C392F;
  font-size: 28rpx;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
}

.icon-section {
  background: #C2CEBD;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  display: flex;
  justify-content: space-around;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.icon-item text {
  font-size: 24rpx;
  color: #1C392F;
}

.contact-info {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.contact-info text {
  color: #C2CEBD;
  font-size: 26rpx;
  line-height: 1.8;
}