page {
  background-color: #1C392F;
}

.edit-container {
  padding: 20rpx 30rpx;
  position: relative;
}

.form-group {
  background: #C2CEBD;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 40rpx;
}

.input-item, .picker-item {
  height: 100rpx;
  border-bottom: 1rpx solid rgba(28, 57, 47, 0.1);
  font-size: 28rpx;
  color: #1C392F;
  display: flex;
  align-items: center;
}

.textarea-item {
  width: 100%;
  height: 200rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #1C392F;
}

.placeholder {
  color: rgba(28, 57, 47, 0.6);
}

.save-btn {
  background: #C2CEBD;
  color: #1C392F;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}